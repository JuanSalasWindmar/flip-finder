generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis]
}

enum PropertyState {
  ORIGINAL
  REMODELED
}

enum PolygonType {
  EXTRACT
  ANALYZE
}

enum PropertyType {
  APARTMENT
  STUDIO
  HOUSE
  COMMERCIAL
  OFFICE
  LOT
  WAREHOUSE
  FARM
}

enum PropertyStatus {
  NEW
  USED
}

model Property {
  id             String        @id @default(uuid())
  link           String
  state          PropertyState
  area           Decimal       @db.Decimal(10, 2)
  price          BigInt
  age            String
  avg_age        Int?           @db.SmallInt
  admin_price    BigInt
  price_per_sqm  Decimal       @db.Decimal(12, 2)
  address        String
  neighborhood   String
  rooms          Int
  bathrooms      Int
  floor          Int
  elevator       Boolean       @default(false)
  stratum        Int           @db.SmallInt
  parking        Boolean       @default(false)
  notes          String?       @db.Text
  latitude       Decimal?      @db.Decimal(10, 7)
  longitude      Decimal?      @db.Decimal(10, 7)
  reviewed       Boolean       @default(false)
  created_at     DateTime      @default(now()) @db.Timestamptz
  extracted_at   DateTime      @db.Timestamptz

  duplicated_of_id String?
  duplicated_of    Property?  @relation("DuplicateGroup", fields: [duplicated_of_id], references: [id])
  duplicates       Property[] @relation("DuplicateGroup")

  potential_properties PotentialProperty[]

  @@map("properties")
}

model Polygon {
  id           String                          @id @default(uuid())
  name         String
  georeference Unsupported("geometry(Polygon, 4326)")
  city         String
  polygon_type PolygonType
  enabled         Boolean                         @default(true)
  property_type   PropertyType?
  property_status PropertyStatus?
  min_price       Int?
  max_price       Int?
  min_bedrooms    Int?                            @db.SmallInt
  max_bedrooms    Int?                            @db.SmallInt
  min_bathrooms   Int?                            @db.SmallInt
  max_bathrooms   Int?                            @db.SmallInt
  min_area        Int?
  max_area        Int?
  min_parking     Int?                            @db.SmallInt
  max_parking     Int?                            @db.SmallInt
  min_stratum     Int?                            @db.SmallInt
  max_stratum     Int?                            @db.SmallInt
  min_age              Int?                            @db.SmallInt
  max_age              Int?                            @db.SmallInt
  deviation_threshold  Int?                            @db.SmallInt
  created_at           DateTime                        @default(now()) @db.Timestamptz
  updated_at           DateTime                        @updatedAt @db.Timestamptz

  executions            Execution[]
  potential_properties  PotentialProperty[]

  @@map("polygons")
}

model PotentialProperty {
  id          String   @id @default(uuid())
  polygon_id  String
  polygon     Polygon  @relation(fields: [polygon_id], references: [id])
  property_id String
  property    Property @relation(fields: [property_id], references: [id])
  created_at  DateTime @default(now()) @db.Timestamptz
  updated_at  DateTime @updatedAt @db.Timestamptz

  @@unique([polygon_id, property_id])
  @@map("potential_properties")
}

enum ExecutionStatus {
  SUCCESS
  FAILED
}

model Execution {
  id               String          @id @default(uuid())
  polygon_id       String
  polygon          Polygon         @relation(fields: [polygon_id], references: [id])
  type             PolygonType
  status           ExecutionStatus
  properties_found Int             @default(0)
  properties_new   Int             @default(0)
  performed_at     DateTime        @db.Timestamptz
  created_at       DateTime        @default(now()) @db.Timestamptz

  @@map("executions")
}
