{
  "name": "flip-finder",
  "version": "0.0.1",
  "private": true,
  "description": "The application that finds you the best property for flipping",
  "scripts": {
    "dev:frontend": "pnpm --filter @flip-finder/frontend dev",
    "dev:backend": "pnpm --filter @flip-finder/backend start:dev",
    "build:frontend": "pnpm --filter @flip-finder/frontend build",
    "build:backend": "pnpm --filter @flip-finder/backend build",
    "extract": "pnpm --filter @flip-finder/scripts extract",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write '**/*.{ts,tsx,js,mjs,json}'",
    "format:check": "prettier --check '**/*.{ts,tsx,js,mjs,json}'"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JuanCamiloSalas/flip-finder.git"
  },
  "author": "Juan Salas",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/JuanCamiloSalas/flip-finder/issues"
  },
  "homepage": "https://github.com/JuanCamiloSalas/flip-finder#readme",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.2.0",
    "prettier": "3.8.1",
    "typescript-eslint": "^8.34.0",
    "typescript": "^5.8.3"
  }
}
